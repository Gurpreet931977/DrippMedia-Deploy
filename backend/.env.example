AGENCY_EMAIL=hello@drippmedia.com

# ─── Admin Dashboard ───────────────────────────────────────────────────────────
# Password to access /admin
ADMIN_PASSWORD=dripp2026

# ─── Flask Secret Key ──────────────────────────────────────────────────────────
# Change this to a long random string in production
SECRET_KEY=dripp-secret-change-me-in-production
